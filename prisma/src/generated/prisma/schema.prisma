// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Book {
  isbn          String  @id @db.Char(13)
  title         String  @db.VarChar(128)
  author        String  @db.VarChar(128)
  location      String? @db.VarChar(128)
  available_qty Int?    @default(0)

  requests BorrowRequests[]

  @@map("books")
}

model BorrowRequests {
  request_id   Int       @id @default(autoincrement())
  bid          Int
  isbn         String    @db.Char(13)
  request_date DateTime? @default(now()) @db.Timestamp(0)
  due_date     DateTime  @db.Timestamp(0)
  returned_at  DateTime? @db.Timestamp(0)

  borrower Borrower @relation(fields: [bid], references: [id])
  book     Book     @relation(fields: [isbn], references: [isbn])

  @@map("borrow_requests")
}

enum UserType {
  BORROWER
  ADMIN
}

enum StatusType {
  ACTIVE
  INACTIVE
}

model User {
  uid                Int        @id @default(autoincrement())
  email              String     @unique
  name               String     @db.VarChar(128)
  password           String
  user_type          UserType   @default(BORROWER)
  status             StatusType @default(ACTIVE)
  registeration_date DateTime?  @db.Timestamp(0)
  borrower           Borrower?
  admin              Admin?

  @@map("users")
}

model Borrower {
  id              Int              @id
  user            User             @relation(fields: [id], references: [uid], onDelete: Cascade)
  membership_date DateTime?        @db.Timestamp(0)
  expiry_date     DateTime?        @db.Timestamp(0)
  requests        BorrowRequests[]

  @@map("borrowers")
}

model Admin {
  id           Int  @id
  user         User @relation(fields: [id], references: [uid], onDelete: Cascade)
  access_level Int  @default(1)

  @@map("admins")
}
